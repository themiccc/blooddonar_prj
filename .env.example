PORT=5000
MONGODB_URI=mongodb://localhost:27017/blood_donor_db
JWT_SECRET=supersecretkey_blood_donor_finder_2026
NODE_ENV=development

# Twilio SMS API Credentials (Required for real SMS delivery to phone numbers)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Razorpay Sandbox payment credentials
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SendGrid API Credentials (Required for real email verification deliveries)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_SENDER_EMAIL=your_verified_sender_email
